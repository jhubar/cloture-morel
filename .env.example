# --- Site ---------------------------------------------------------------
# Public base URL (used for SEO metadata, sitemap, canonical, OpenGraph).
NEXT_PUBLIC_SITE_URL=https://clotures-morel.be

# --- E-mail (Resend) ----------------------------------------------------
# Get an API key at https://resend.com. If RESEND_API_KEY is left empty,
# the site still works: forms succeed and the materials quote PDF is still
# generated and downloadable — only the e-mail sending is skipped.
RESEND_API_KEY=

# Verified sender. Must be a domain verified in Resend, e.g.
# "Clôtures Morel <devis@clotures-morel.be>". During tests you can use
# "Clôtures Morel <onboarding@resend.dev>".
EMAIL_FROM=

# Where Nicolas receives quote/contact notifications (official inbox).
QUOTE_NOTIFICATION_EMAIL=Clotures-morel@outlook.com

# (Optional, TEST ONLY) When set, EVERY e-mail (admin + client confirmation)
# is redirected to this single address, ignoring the form's e-mail. Leave
# empty in production.
EMAIL_TEST_REDIRECT=
